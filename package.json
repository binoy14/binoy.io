{
  "private": true,
  "name": "binoy.io",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "sanity:deploy": "turbo run deploy --filter='./apps/sanity'",
    "sanity:typegen": "turbo run typegen --filter='./apps/sanity'"
  },
  "devDependencies": {
    "@binoy/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "turbo": "^2.9.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,css,json,html,md}": "prettier --write"
  },
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "pnpm": ">=10"
  }
}
