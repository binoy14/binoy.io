{
  "name": "binoy.io",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "oxfmt",
    "sanity:deploy": "turbo run deploy --filter='./apps/sanity'",
    "sanity:typegen": "turbo run typegen --filter='./apps/sanity'"
  },
  "devDependencies": {
    "@binoy/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.56.0",
    "turbo": "^2.9.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,svelte,css,json,md}": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.34.3"
}
